generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Pharmacy {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  customers      Customer[]
  products       Product[]
  stockBatches   StockBatch[]
  stockMovements StockMovement[]
  salesOrders    SalesOrder[]
  orderItems     OrderItem[]
  purchaseOrders PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  distributors   Distributor[]
  territories    Territory[]
  kpis           Kpi[]
  promotions     Promotion[]
  priceLists     PriceList[]
  complianceRecords ComplianceRecord[]
  taxSettings    TaxSetting[]
  settings       Setting[]
}

model User {
  id         Int      @id @default(autoincrement())
  pharmacyId Int
  code       String
  name       String
  email      String   @unique
  password   String
  phone      String?
  role       String   @default("sales") // admin, warehouse, sales, pharmacy-rep, accountant, distribution, customer-care, ceo, marketing-manager
  department String?
  position   String?
  status     String   @default("active")
  territory  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pharmacy      Pharmacy       @relation(fields: [pharmacyId], references: [id])
  salesOrders   SalesOrder[]
  purchaseOrders PurchaseOrder[]
  customers     Customer[]
  kpis          Kpi[]

  @@unique([pharmacyId, code])
}

model Customer {
  id          Int      @id @default(autoincrement())
  pharmacyId  Int
  code        String
  name        String
  type        String   // pharmacy, hospital, clinic, distributor, wholesaler, retailer
  taxCode     String?
  phone       String?
  email       String?
  address     String?
  region      String?  // north, central, south
  creditLimit Float    @default(0)
  status      String   @default("active") // active, potential, inactive, blacklist
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  salesPersonId Int?
  salesPerson   User?   @relation(fields: [salesPersonId], references: [id])

  pharmacy    Pharmacy     @relation(fields: [pharmacyId], references: [id])
  salesOrders SalesOrder[]

  @@unique([pharmacyId, code])
}

model MasterProduct {
  id               Int      @id @default(autoincrement())
  code             String   @unique
  name             String
  activeIngredient String?
  category         String   // prescription, otc, supplement, medical-device, consumable
  manufacturer     String?
  unit             String   // Viên, Lọ, Hộp, Chai, Túi
  description      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pharmacyProducts Product[]
}

model Product {
  id               Int      @id @default(autoincrement())
  pharmacyId       Int
  masterProductId  Int?
  code             String
  name             String
  activeIngredient String?
  category         String   // prescription, otc, supplement, medical-device, consumable
  manufacturer     String?
  unit             String   // Viên, Lọ, Hộp, Chai, Túi
  purchasePrice    Float    @default(0)
  salePrice        Float    @default(0)
  minStock         Int      @default(0)
  status           String   @default("active") // active, discontinued, pending
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pharmacy           Pharmacy              @relation(fields: [pharmacyId], references: [id])
  masterProduct      MasterProduct?        @relation(fields: [masterProductId], references: [id])
  stockBatches       StockBatch[]
  stockMovements     StockMovement[]
  orderItems         OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  priceLists         PriceList[]

  @@unique([pharmacyId, code])
}

model StockBatch {
  id          Int      @id @default(autoincrement())
  pharmacyId  Int
  productId   Int
  batchNumber String
  expiryDate  DateTime
  warehouse   String   @default("main") // main, cold, quarantine, return
  quantity    Int      @default(0)
  unit        String
  purchasePrice Float  @default(0)
  salePrice   Float    @default(0)
  status      String   @default("in-stock") // in-stock, low-stock, expiring, expired, out-of-stock
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
}

model StockMovement {
  id          Int      @id @default(autoincrement())
  pharmacyId  Int
  date        DateTime @default(now())
  type        String   // in, out, transfer, adjustment
  productId   Int
  batchNumber String?
  quantity    Int
  fromWarehouse String?
  toWarehouse   String?
  referenceType String? // sales-order, purchase-order, adjustment
  referenceId   Int?
  note        String?
  createdBy   String?
  createdAt   DateTime @default(now())

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
}

model SalesOrder {
  id          Int      @id @default(autoincrement())
  pharmacyId  Int
  code        String
  customerId  Int
  salesPersonId Int?
  orderDate   DateTime @default(now())
  deliveryDate DateTime?
  totalAmount Float    @default(0)
  status      String   @default("pending") // pending, confirmed, processing, shipped, completed, cancelled
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pharmacy    Pharmacy     @relation(fields: [pharmacyId], references: [id])
  customer    Customer     @relation(fields: [customerId], references: [id])
  salesPerson User?        @relation(fields: [salesPersonId], references: [id])
  items       OrderItem[]

  @@unique([pharmacyId, code])
}

model OrderItem {
  id         Int    @id @default(autoincrement())
  pharmacyId Int
  orderId    Int
  productId  Int
  quantity   Int
  unitPrice  Float
  totalPrice Float

  pharmacy Pharmacy   @relation(fields: [pharmacyId], references: [id])
  order    SalesOrder @relation(fields: [orderId], references: [id])
  product  Product    @relation(fields: [productId], references: [id])
}

model PurchaseOrder {
  id          Int      @id @default(autoincrement())
  pharmacyId  Int
  code        String
  supplierName String
  supplierId  String?
  orderDate   DateTime @default(now())
  deliveryDate DateTime?
  totalAmount Float    @default(0)
  priority    String   @default("normal") // urgent, high, normal, low
  status      String   @default("draft") // draft, pending, approved, ordered, received, completed
  createdById Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pharmacy  Pharmacy             @relation(fields: [pharmacyId], references: [id])
  createdBy User?                @relation(fields: [createdById], references: [id])
  items     PurchaseOrderItem[]

  @@unique([pharmacyId, code])
}

model PurchaseOrderItem {
  id              Int    @id @default(autoincrement())
  pharmacyId      Int
  purchaseOrderId Int
  productId       Int
  quantity        Int
  unitPrice       Float
  totalPrice      Float

  pharmacy      Pharmacy      @relation(fields: [pharmacyId], references: [id])
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
}

model Distributor {
  id           Int      @id @default(autoincrement())
  pharmacyId   Int
  code         String
  name         String
  type         String   // exclusive, non-exclusive
  region       String?  // north, central, south
  revenue      Float    @default(0)
  commission   Float    @default(0)
  status       String   @default("active")
  contractDate DateTime?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])

  @@unique([pharmacyId, code])
}

model Territory {
  id          Int      @id @default(autoincrement())
  pharmacyId  Int
  name        String
  managerId   Int?
  customerCount Int    @default(0)
  revenue     Float    @default(0)
  potential   String   @default("medium")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])
}

model Kpi {
  id            Int      @id @default(autoincrement())
  pharmacyId    Int
  userId        Int
  period        String   // monthly, quarterly, yearly
  revenueTarget Float    @default(0)
  revenueActual Float    @default(0)
  customerTarget Int     @default(0)
  customerActual Int     @default(0)
  orderTarget   Int      @default(0)
  orderActual   Int      @default(0)
  totalScore    Float    @default(0)
  periodStart   DateTime
  periodEnd     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}

model Promotion {
  id          Int      @id @default(autoincrement())
  pharmacyId  Int
  code        String
  name        String
  type        String   // discount, combo, campaign
  value       Float
  startDate   DateTime
  endDate     DateTime
  status      String   @default("active")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])

  @@unique([pharmacyId, code])
}

model PriceList {
  id        Int      @id @default(autoincrement())
  pharmacyId Int
  name      String
  type      String   // wholesale, retail, special
  productId Int
  price     Float
  startDate DateTime?
  endDate   DateTime?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
}

model ComplianceRecord {
  id          Int      @id @default(autoincrement())
  pharmacyId  Int
  type        String   // license, audit, regulatory-report
  title       String
  description String?
  status      String   @default("active")
  expiryDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])
}

model TaxSetting {
  id        Int      @id @default(autoincrement())
  pharmacyId Int
  name      String
  rate      Float
  type      String   // vat, special, import
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])
}

model Setting {
  id          Int      @id @default(autoincrement())
  pharmacyId  Int
  key         String
  value       String
  description String?

  pharmacy Pharmacy @relation(fields: [pharmacyId], references: [id])

  @@unique([pharmacyId, key])
}

model Lookup {
  id        Int      @id @default(autoincrement())
  category  String
  value     String
  label     String
  color     String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, value])
}

model NavigationItem {
  id         Int      @id @default(autoincrement())
  href       String   @unique
  label      String
  icon       String
  permission String
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RolePermission {
  id         Int      @id @default(autoincrement())
  role       String
  permission String

  @@unique([role, permission])
}
